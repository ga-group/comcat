ccat:254010
	a	skos:Concept ;
	skos:broader	ccat:2540 ;
	skos:definition	"Production data refer to raw milk containing all its constituents. Trade data normally cover milk from any animal, and refer to milk that is not concentrated, pasteurized, sterilized or other-wise preserved, homogenized or peptonized."@en ;
	skos:inScheme	ccat: ;
	skos:notation	"254010" ;
	skos:prefLabel	"Cow Milk"@en .

ccat:25401010
	a	skos:Concept ;
	skos:broader	ccat:254010 ;
	skos:definition	"Milk in which the fat content is adjusted to a predetermined value without altering any other constituents."@en ;
	skos:inScheme	ccat: ;
	skos:notation	"25401010" ;
	skos:prefLabel	"Standardized Milk"@en .

ccat:25401011
	a	skos:Concept ;
	skos:broader	ccat:254010 ;
	skos:definition	"Milk and cream from which water has been partly removed after heat-treating and concentrating. Normally sucrose is added to give the product stability and bacteriological safety."@en ;
	skos:inScheme	ccat: ;
	skos:notation	"25401011" ;
	skos:prefLabel	"Condensed Whole Milk"@en .

ccat:25401012
	a	skos:Concept ;
	skos:broader	ccat:254010 ;
	skos:definition	"Milk and cream from which the water has been partly removed and which has been heat- treated to render it bacteriologically safe and stable."@en ;
	skos:inScheme	ccat: ;
	skos:notation	"25401012" ;
	skos:prefLabel	"Evaporated Whole Milk"@en .

ccat:25401013
	a	skos:Concept ;
	skos:broader	ccat:254010 ;
	skos:definition	"Milk and cream from which water has been completely removed by various methods. In form of powder, granules or other solid forms. May contain added sugar or other sweeteners."@en ;
	skos:inScheme	ccat: ;
	skos:notation	"25401013" ;
	skos:prefLabel	"Dry Whole Cow Milk"@en .

ccat:25401015
	a	skos:Concept ;
	skos:broader	ccat:254010 ;
	skos:definition	"That portion of milk which is rich in milk fat and is separated by skimming or centrifuging."@en ;
	skos:inScheme	ccat: ;
	skos:notation	"25401015" ;
	skos:prefLabel	"Fresh Cream"@en .

ccat:25401016
	a	skos:Concept ;
