	skos:altLabel	"TSR"@en ;
	skos:broader	ccat:3040 ;
	skos:definition	"Naturally coagulated rubber (cup lump) that has been reduced in size, cleaned and dried, then baled and palletised for storage and shipment."@en ;
	skos:inScheme	ccat: ;
	skos:notation	"304025" ;
	skos:prefLabel	"Technically Specified Rubber"@en .

ccat:304027
