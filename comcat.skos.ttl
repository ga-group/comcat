ccat:25401031
	a	skos:Concept ;
	skos:broader	ccat:254010 ;
	skos:definition	"Condensed whey is pasteurised fresh whey where some of the liquid has been evaporated in a vaccum forming a paste that can then be dried to produce dry whey."@en ;
