	skos:broader	ccat:2035 ;
	skos:definition	"""The adzuki bean is an annual vine widely cultivated throughout East Asia for its small (approximately 5 millimetres (0.20 in) long) bean. The cultivars most familiar in East Asia have a uniform red color, but there are also white, black, gray, and variously mottled varieties."""@en ;
	skos:exactMatch	agrovoc:c_8632 , wd:Q380279 ;
