ccat:25401030
	a	skos:Concept ;
	skos:broader	ccat:254010 ;
	skos:definition	"The liquid part of the milk that remains after the separation of curd in cheese making. Its main food use is in the preparation of whey cheese, whey drinks and fermented whey drinks. The main industrial uses are in the manufacture of lactose, whey paste and dried whey."@en ;
	skos:exactMatch	agrovoc:c_8376 , wd:Q185009 ;
