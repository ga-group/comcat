ccat:3050
	a	skos:Concept ;
	skos:broader	ccat:30 ;
	skos:definition	"Compounds that do not contain a C atom. Exceptions are made for isocyanide/cyanide and their non-hydrocarbyl derivatives, thiophosgene, carbon diselenide, carbon monosulfide, carbon disulfide, carbon subsulfide, carbon monoxide, carbon trioxide, carbon suboxide, and dicarbon monoxide."@en ;
	skos:exactMatch	<http://classyfire.wishartlab.com/tax_nodes/C0000001> , agrovoc:c_3881 ;
	skos:inScheme	ccat: ;
	skos:notation	"3050" ;
	skos:prefLabel	"Inorganic Compounds"@en .

ccat:305010
	a	skos:Concept ;
	skos:altLabel	"Soda Ash"@en , "Washing Soda"@en ;
	skos:broader	ccat:3050 ;
	skos:definition	"Sodium carbonate is a food additive (E500) used as an acidity regulator, anticaking agent, raising agent, and stabilizer. Sodium carbonate is also used as a relatively strong base in various fields. As a common alkali, it is preferred in many chemical processes because it is cheaper than sodium hydroxide and far safer to handle."@en ;
	skos:exactMatch	<http://classyfire.wishartlab.com/entities/CDBYLPFSWZWCQE-UHFFFAOYSA-L> ;
	skos:inScheme	ccat: ;
	skos:notation	"305010" ;
	skos:prefLabel	"Sodium Carbonate"@en .

ccat:305020
	a	skos:Concept ;
	skos:broader	ccat:3050 ;
	skos:definition	"""Glass is a non-crystalline, often transparent amorphous solid, that has widespread practical, technological, and decorative use in, for example, window panes, tableware, and optics. Glass is most often formed by rapid cooling (quenching) of the molten form.

The most familiar, and historically the oldest, types of manufactured glass are \"silicate glasses\" based on the chemical compound silica (silicon dioxide, or quartz), the primary constituent of sand. Soda-lime glass, containing around 70% silica, accounts for around 90% of manufactured glass."""@en ;
	skos:inScheme	ccat: ;
	skos:notation	"305020" ;
	skos:prefLabel	"Glass"@en .

